# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@postgres:5435/clipboard?sslmode=disable

# 32-byte AES key encoded as 64 lowercase hex characters.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=a933b173636e653cb9d8c13d1a57ad7846bbfe6c827c65bb070a497d9e191eaa

# Redis URL for caching and rate limiting.
# If omitted, cache is disabled and rate limiting falls back to a no-op.
REDIS_URL=redis://redis:6379/0

# HTTP port (default: 8080)
PORT=8080

# Log level: debug | info | warn | error  (default: info)
LOG_LEVEL=debug

# Maximum allowed requests per IP per window (default: 40)
RATE_LIMIT_MAX=40

# Rate limit sliding window in seconds (default: 60)
RATE_LIMIT_WINDOW_SEC=60

# Comma-separated list of allowed CORS origins, or * for wildcard (default: *)
ALLOWED_ORIGINS=*
